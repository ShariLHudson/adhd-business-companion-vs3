{
  "registry": "room-placement-library",
  "version": "2.0.0",
  "description": "Approved in-scene Discovery Key™ placement zones per Estate room. The Estate Intelligence Engine selects ONE location per placement — never ad hoc UI coordinates.",
  "supabase": {
    "tableName": "room_placement_library",
    "childTableName": "room_placement_locations",
    "notes": "V1 reads JSON. Future: rooms row + locations rows; seasonal variants as JSONB."
  },
  "statusValues": ["Live", "Draft", "Future", "Hidden", "Retired"],
  "surfaceTypes": [
    "mantel",
    "desk",
    "windowsill",
    "table",
    "shelf",
    "bookshelf",
    "bench",
    "railing",
    "flower-pot",
    "chair",
    "cabinet",
    "dock",
    "rock",
    "bridge",
    "telescope-table",
    "potting-table",
    "stone-wall",
    "audio-cabinet",
    "floor"
  ],
  "placementRules": {
    "diegeticOnly": true,
    "maxKeysPerRoom": 1,
    "maxKeysEstateWide": 1,
    "neverBlock": [
      "buttons",
      "primary-navigation",
      "conversation-panel",
      "folded-map",
      "artwork-focal",
      "readable-text",
      "accessibility-targets"
    ],
    "neverOverlap": ["navigation", "member-facing-copy", "critical-scene-focal"],
    "stableWhileInRoom": true,
    "coordinatesAreRefinable": true
  },
  "itemSchema": {
    "roomId": "string — must match estate-rooms.json id",
    "officialName": "string",
    "status": "Live | Draft | Future | Hidden | Retired",
    "sceneImage": "string | null — default room plate",
    "preferredLightingNotes": "string — warm light, lantern, fireplace guidance",
    "defaultPlacementScale": "number — room-level default key scale (0–1)",
    "safeArea": "SafeAreaDefinition",
    "visibilityRules": "RoomVisibilityRules",
    "seasonalVariants": "SeasonalPlacementVariant[]",
    "approvedLocations": "ApprovedKeyLocation[]",
    "lastUpdated": "ISO date"
  },
  "locationSchema": {
    "id": "string — stable within room",
    "label": "string — human name, e.g. Fireplace Mantel",
    "surfaceType": "surfaceTypes value",
    "status": "Live | Draft | Future | Hidden | Retired",
    "description": "string | null",
    "placementScale": "number | null — overrides room default",
    "rotationDegrees": "number",
    "depthLayer": "scene | object | foreground",
    "position": "{ xPercent, yPercent, anchor }",
    "shadow": "{ enabled, opacity, blurPx, offsetYPercent }",
    "lightingAdjustment": "{ warmth, highlight }",
    "safePlacementZone": "{ notes, avoidOverlapWith }",
    "priority": "number — lower = preferred when multiple eligible",
    "seasonalOnly": "string | null — season id when location appears only in seasonal art"
  },
  "canonicalAssets": {
    "discoveryKey": {
      "officialName": "Discovery Key™",
      "path": "/images/discovery-key.png",
      "repositoryPath": "public/images/discovery-key.png",
      "visualReference": "docs/estate-intelligence/discovery-key/DiscoveryKey-Visual-Reference.md",
      "reuseRule": "Single asset estate-wide — no alternate key designs"
    }
  },
