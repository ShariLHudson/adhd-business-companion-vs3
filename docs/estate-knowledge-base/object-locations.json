{
  "registry": "object-locations",
  "version": "1.0.0",
  "description": "Where estate objects appear in scene — placement and location binding for Object Intelligence™.",
  "rules": {
    "locationIdMatchesEstateLocations": true,
    "objectIdMatchesEstateObjects": true
  },
  "itemSchema": {
    "locationId": "string — estate-locations.locationId",
    "objectId": "string — estate-objects.objectId",
    "placementLabel": "string — human label, e.g. Telescope Table",
