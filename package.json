{
  "name": "companion-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/generate-shari-photo-manifest.mjs && node scripts/companion-audit-guardrail.mjs dev && next dev -p 3000 --webpack",
    "build": "node scripts/generate-shari-photo-manifest.mjs,
    "manifest:shari-photos": "node scripts/generate-shari-photo-manifest.mjs",
    "start": "next start -p 3000",
    "lint": "eslint",
    "test": "vitest run",
    "audit:companion": "vitest run lib/companionBehaviorAudit.test.ts",
    "audit:companion:record": "vitest run lib/companionBehaviorAudit.test.ts && node scripts/companion-audit-guardrail.mjs record",
    "audit:companion:report": "vitest run lib/companionBehaviorAudit.test.ts --reporter=verbose",
    "audit:companion:latency": "vitest run lib/companionLatencyProfiler.test.ts && npx tsx scripts/companion-latency-qa.ts",
    "audit:companion:check": "node scripts/companion-audit-guardrail.mjs check",
    "setup:hooks": "node scripts/install-companion-git-hooks.mjs",
    "postinstall": "node scripts/install-companion-git-hooks.mjs",
    "welcome-voice:setup": "node scripts/set-elevenlabs-env.mjs",
    "welcome-voice:check": "node scripts/check-elevenlabs-env.mjs",
    "welcome-voice:list": "node scripts/list-elevenlabs-voices.mjs",
    "welcome-voice:cache": "node scripts/generate-welcome-voice-cache.mjs",
    "curriculum:scan": "npx tsx scripts/curriculum/scan-curriculum-registry.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "jspdf": "^4.2.1",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
